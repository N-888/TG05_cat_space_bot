# Игнорируем виртуальные окружения, чтобы не загружать их в репозиторий.
venv/

# Игнорируем альтернативное имя виртуального окружения.
.venv/

# Игнорируем служебный кэш Python.
__pycache__/

# Игнорируем скомпилированные Python-файлы.
*.pyc

# Игнорируем локальный файл с секретами и ключами.
.env

# Игнорируем служебные файлы PyCharm.
.idea/